# Square API (leave empty to use mock data)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# Email Alerts (leave empty to skip sending — alerts will be logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# Daily alert time (HH:MM, local time)
ALERT_TIME=08:00

# App
DEBUG=true
USE_MOCK_DATA=true
